{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "types": ["node"],
    
    /* File Layout */
    "rootDir": "./src",
    "outDir": "./dist",
    
    /* Type Checking & Safety */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    
    /* Build Outputs */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*"]
}